<?xml version="1.0" encoding="utf-8"?>
<!--
    Tall layout (used when the widget is ≥3 cells wide).
    Kept deliberately conservative — avoids attributes that have
    historically tripped RemoteViews inflation in some launchers:
      - no `android:alpha` (white-with-alpha hex colors instead)
      - no `android:autoSizeTextType` (fixed sizes, single ellipsize)
      - no `layout_gravity` inside vertical parents
    Same chip structure as the medium layout so the provider's
    populate helper can drive both with the same IDs.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/sentence_widget_bg"
    android:padding="12dp">

    <!-- Top half: today's sentence. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="3"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_pron"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="#BFFFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="#F2FFFFFF"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:id="@+id/widget_words_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp">

            <LinearLayout
                android:id="@+id/widget_word_0"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/sentence_widget_chip"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="3dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/widget_word_0_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
                <TextView
                    android:id="@+id/widget_word_0_meaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#D9FFFFFF"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_word_1"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/sentence_widget_chip"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/widget_word_1_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
                <TextView
                    android:id="@+id/widget_word_1_meaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#D9FFFFFF"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_situation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Divider (RemoteViews doesn't allow plain <View>, FrameLayout
         is on the safe list and renders the same 1dp horizontal rule
         once we give it a tinted background). -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="#33FFFFFF" />

    <!-- Bottom half: secondary vocab card -->
    <LinearLayout
        android:id="@+id/secondary_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/secondary_word"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textSize="17sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/secondary_meaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textColor="#D9FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/secondary_sentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/secondary_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#C7FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
