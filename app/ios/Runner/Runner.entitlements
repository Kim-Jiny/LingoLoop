<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  APNs entitlement is REQUIRED for iOS to issue an APNs device
	  token to the app. Without it, FirebaseMessaging.getToken() hangs
	  forever waiting on an APNs token that never arrives, and no
	  push notifications can be delivered.

	  `development` here works for Debug + Run-from-Xcode + ad-hoc
	  TestFlight uploads built with a Development provisioning
	  profile. When Xcode archives with an App Store / Distribution
	  profile, it automatically substitutes `production` at build
	  time. The key just has to be present — Xcode picks the right
	  value off the active provisioning profile.
	-->
	<key>aps-environment</key>
	<string>development</string>
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.jiny.lingoloop</string>
	</array>
	<!--
	  Universal Links — lingo.jiny.shop의 모든 https URL을 앱이 받음.
	  Apple swcd가 https://lingo.jiny.shop/.well-known/apple-app-site-
	  association 을 fetch해 검증. 검증 통과한 후 사용자가 그 도메인의
	  링크를 탭하면 Safari가 아닌 앱이 열림(설치된 경우).
	  '?mode=developer' suffix 없는 production 발급 인증서 기준 동작.
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:lingo.jiny.shop</string>
	</array>
</dict>
</plist>
