DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=lingoloop
DB_PASSWORD=lingoloop_dev_password
DB_DATABASE=lingoloop

JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

PORT=3000
NODE_ENV=development

# Admin dashboard. Required before the first production boot.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=

# Paid plan master switch. Free-only release: keep false (or unset).
# Set to true when launching premium so the scheduler may send quiz pushes.
PREMIUM_ENABLED=false

# Social login
# Google: comma-separated OAuth client IDs allowed as id_token audience
# (web/iOS/Android client IDs from Google/Firebase console).
GOOGLE_CLIENT_IDS=
# Apple: expected audience of the identity token (iOS bundle id, or the
# Services ID for Android/web Sign in with Apple). Defaults to bundle id.
APPLE_AUDIENCE=com.jiny.lingoloop
# Kakao needs no server secret (access token is verified via Kakao API).
